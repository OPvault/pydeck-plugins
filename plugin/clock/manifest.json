{
  "name": "clock",
  "version": "1.0.0",
  "description": "Display a live digital or analog clock on a button",
  "author": "PyDeck Team",
  "permissions": {
    "datetime": ["datetime"],
    "math": ["cos", "sin", "radians"],
    "pathlib": ["Path"],
    "hashlib": ["md5"]
  },
  "functions": {
    "show_clock": {
      "label": "Clock",
      "description": "Show a live digital or analog clock that updates every second",
      "default_display": {
        "color": "#000000",
        "text": "00:00"
      },
      "poll": {
        "function": "poll_clock",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "radio",
          "id": "clock_style",
          "label": "Style",
          "default": "digital",
          "options": [
            {"label": "Digital", "value": "digital"},
            {"label": "Analog",  "value": "analog"}
          ]
        },
        {
          "type": "checkbox",
          "id": "show_seconds",
          "label": "Show seconds",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "digital_overlay",
          "label": "Show digital time inside analog face",
          "default": false,
          "visible_if": {"field": "clock_style", "value": "analog"}
        }
      ]
    }
  }
}
