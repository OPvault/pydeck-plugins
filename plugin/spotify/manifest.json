{
  "name": "spotify",
  "version": "1.0.0",
  "description": "Control Spotify playback via the Web API",
  "author": "PyDeck Team",
  "oauth": {
    "authorize_url": "https://accounts.spotify.com/authorize",
    "token_url": "https://accounts.spotify.com/api/token",
    "scopes": "user-read-playback-state user-modify-playback-state user-read-currently-playing",
    "auth_method": "basic"
  },
  "credentials": [
    {"id": "client_id",     "label": "Client ID",     "type": "text"},
    {"id": "client_secret", "label": "Client Secret", "type": "password"}
  ],
  "permissions": {
    "urllib.request": ["urlopen", "Request"],
    "urllib.parse": ["urlencode"],
    "urllib.error": ["HTTPError"],
    "base64": ["b64encode"],
    "hashlib": ["sha256"],
    "json": ["dumps", "loads"],
    "threading": ["Lock"],
    "pathlib": ["Path"]
  },
  "functions": {
    "play_pause": {
      "label": "Play / Pause",
      "description": "Toggle Spotify play/pause",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/_now_playing.jpg"
      },
      "poll": {
        "function": "poll_display",
        "interval_ms": 3000
      },
      "ui": [
        {
          "type": "radio",
          "id": "display_mode",
          "label": "Display Text",
          "default": "song",
          "options": [
            {"value": "none",        "label": "None"},
            {"value": "song",        "label": "Song"},
            {"value": "song_artist", "label": "Song - Artist"},
            {"value": "artist",      "label": "Artist"}
          ]
        }
      ]
    },
    "next_track": {
      "label": "Next Track",
      "description": "Skip to the next Spotify track",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/Next.png"
      },
      "ui": []
    },
    "prev_track": {
      "label": "Previous Track",
      "description": "Go back to the previous Spotify track",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/Previous.png"
      },
      "ui": []
    },
    "volume_up": {
      "label": "Volume Up",
      "description": "Increase Spotify volume",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/VolumeUp.png"
      },
      "poll": {
        "function": "poll_volume_display",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "number",
          "id": "volume_step",
          "label": "Volume Step (%)",
          "min": 1,
          "max": 100,
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "show_volume_label",
          "label": "Show Volume %",
          "default": false
        }
      ]
    },
    "volume_down": {
      "label": "Volume Down",
      "description": "Decrease Spotify volume",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/VolumeDown.png"
      },
      "poll": {
        "function": "poll_volume_display",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "number",
          "id": "volume_step",
          "label": "Volume Step (%)",
          "min": 1,
          "max": 100,
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "show_volume_label",
          "label": "Show Volume %",
          "default": false
        }
      ]
    },
    "toggle_shuffle": {
      "label": "Shuffle",
      "description": "Toggle Spotify shuffle mode on/off",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/Shuffle.png"
      },
      "ui": []
    },
    "cycle_repeat": {
      "label": "Repeat",
      "description": "Cycle repeat mode: off → context → track → off",
      "default_display": {
        "color": "#1DB954",
        "text": "",
        "image": "plugins/plugin/spotify/img/Repeat.png"
      },
      "ui": []
    }
  }
}
