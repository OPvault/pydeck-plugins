{
  "name": "Weather",
  "version": "2.0.0",
  "description": "Current weather and multi-hour forecasts powered by met.no",
  "author": "PyDeck Team",
  "min_pydeck_version": "1.1.0",
  "max_pydeck_version": null,
  "permissions": {
    "json": ["loads"],
    "urllib.request": ["Request", "urlopen"],
    "urllib.parse": ["urlencode"],
    "urllib.error": ["HTTPError", "URLError"],
    "re": ["match"]
  },

  "functions": {
    "weather": {
      "label": "Current Weather",
      "description": "Display current temperature, tap for high/low details",
      "title_readonly": true,
      "disableGallary": true,
      "default_display": {
        "color": "#4facfe",
        "text": "Weather",
        "text_font": "Adwaita Sans",
        "text_position": "bottom",
        "scroll_enabled": false
      },
      "poll": {
        "function": "on_poll",
        "interval_ms": 60000
      },
      "ui": [
        {
          "type": "input",
          "id": "location",
          "label": "Location (city or lat,lon)",
          "placeholder": "Oslo or 59.91,10.75",
          "default": "Oslo",
          "autosave": "off",
          "help_text": "Find a location on yr and copy city name or coordinates:",
          "help_label": "Open yr.no",
          "help_url": "https://www.yr.no/en"
        },
        {
          "type": "select",
          "id": "temperature_unit",
          "label": "Temperature Unit",
          "default": "C",
          "options": [
            { "label": "Celsius (°C)", "value": "C" },
            { "label": "Fahrenheit (°F)", "value": "F" },
            { "label": "Kelvin (K)", "value": "K" }
          ]
        },
        {
          "type": "select",
          "id": "temperature_rounding",
          "label": "Temperature Rounding",
          "default": "nearest",
          "options": [
            { "label": "No Rounding (1 decimal)", "value": "none" },
            { "label": "Round Down", "value": "down" },
            { "label": "Round Up", "value": "up" },
            { "label": "Round Nearest", "value": "nearest" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_temperature_unit",
          "label": "Show °C / °F / K Symbol",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "dynamic_background",
          "label": "Dynamic background based on weather",
          "default": true
        }
      ],
      "pdk": true
    },
    "forecast": {
      "label": "Multiple Forecasts",
      "description": "Display 3 weather forecasts at configurable intervals",
      "title_readonly": true,
      "disableGallary": true,
      "default_display": {
        "color": "#4facfe",
        "text": "Forecast",
        "text_font": "Adwaita Sans",
        "text_position": "bottom",
        "scroll_enabled": false
      },
      "poll": {
        "function": "on_poll",
        "interval_ms": 60000
      },
      "ui": [
        {
          "type": "input",
          "id": "location",
          "label": "Location (city or lat,lon)",
          "placeholder": "Oslo or 59.91,10.75",
          "default": "Oslo",
          "autosave": "off",
          "help_text": "Find a location on yr and copy city name or coordinates:",
          "help_label": "Open yr.no",
          "help_url": "https://www.yr.no/en"
        },
        {
          "type": "select",
          "id": "forecast_interval",
          "label": "Forecast Interval",
          "default": "1",
          "options": [
            { "label": "1 Hour (next 3 hours)", "value": "1" },
            { "label": "3 Hours (next 9 hours)", "value": "3" },
            { "label": "6 Hours (next 18 hours)", "value": "6" },
            { "label": "12 Hours (next 36 hours)", "value": "12" },
            { "label": "24 Hours (next 3 days)", "value": "24" }
          ]
        },
        {
          "type": "checkbox",
          "id": "exclude_current",
          "label": "Skip current time (start at next interval)",
          "default": false,
          "visible_if": { "field": "forecast_interval", "not_value": "24" }
        },
        {
          "type": "radio",
          "id": "display_mode",
          "label": "Display Mode",
          "default": "time",
          "options": [
            { "label": "Time only (e.g. '20')", "value": "time" },
            { "label": "Day + Time (e.g. 'Fri 20')", "value": "day" },
            { "label": "Weather Icons", "value": "icons" }
          ]
        },
        {
          "type": "select",
          "id": "temperature_unit",
          "label": "Temperature Unit",
          "default": "C",
          "options": [
            { "label": "Celsius (°C)", "value": "C" },
            { "label": "Fahrenheit (°F)", "value": "F" },
            { "label": "Kelvin (K)", "value": "K" }
          ]
        },
        {
          "type": "select",
          "id": "temperature_rounding",
          "label": "Temperature Rounding",
          "default": "nearest",
          "options": [
            { "label": "No Rounding (1 decimal)", "value": "none" },
            { "label": "Round Down", "value": "down" },
            { "label": "Round Up", "value": "up" },
            { "label": "Round Nearest", "value": "nearest" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_temperature_unit",
          "label": "Show °C / °F / K Symbol",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "dynamic_background",
          "label": "Dynamic background based on weather",
          "default": true
        }
      ],
      "pdk": true
    }
  },
  "pdk": true
}
