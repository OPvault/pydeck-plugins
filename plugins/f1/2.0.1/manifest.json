{
  "name": "F1",
  "version": "2.0.1",
  "description": "Formula 1 race countdown, driver standings, and constructor standings",
  "author": "PyDeck Team",
  "min_pydeck_version": "1.1.0",
  "max_pydeck_version": null,
  "python_dependencies": ["Pillow"],
  "permissions": {
    "urllib.request": ["urlopen", "Request"],
    "urllib.error": ["URLError"],
    "json": ["loads"],
    "datetime": ["datetime", "timezone", "timedelta"],
    "pathlib": ["Path"]
  },
  "functions": {
    "next_race": {
      "label": "F1 Next Race",
      "description": "Countdown to the next Formula 1 race weekend with circuit track icon",
      "disableGallery": true,
      "disableGallary": true,
      "title_readonly": true,
      "default_display": {
        "color": "#e10600",
        "text": "F1"
      },
      "poll": {
        "function": "on_poll",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "group",
          "id": "sessions_group",
          "label": "Sessions",
          "fields": [
            { "type": "checkbox", "id": "include_practice_1",        "label": "Practice 1",        "default": false },
            { "type": "checkbox", "id": "include_practice_2",        "label": "Practice 2",        "default": false },
            { "type": "checkbox", "id": "include_practice_3",        "label": "Practice 3",        "default": false },
            { "type": "checkbox", "id": "include_sprint_qualifying", "label": "Sprint Qualifying", "default": true  },
            { "type": "checkbox", "id": "include_sprint_race",       "label": "Sprint Race",       "default": true  },
            { "type": "checkbox", "id": "include_qualifying",        "label": "Qualifying",        "default": true  },
            { "type": "checkbox", "id": "include_race",              "label": "Race",              "default": true  }
          ]
        },
        {
          "type": "group",
          "id": "countdown_group",
          "label": "Countdown",
          "fields": [
            { "type": "checkbox", "id": "show_days",    "label": "Days",    "default": true  },
            { "type": "checkbox", "id": "show_hours",   "label": "Hours",   "default": true  },
            { "type": "checkbox", "id": "show_minutes", "label": "Minutes", "default": false },
            { "type": "checkbox", "id": "show_seconds", "label": "Seconds", "default": false }
          ]
        },
        {
          "type": "group",
          "id": "display_group",
          "label": "Display",
          "fields": [
            { "type": "checkbox", "id": "show_session_label", "label": "Session Label",        "default": true   },
            { "type": "checkbox", "id": "show_track_label",   "label": "Track Name & Country", "default": false  },
            { "type": "checkbox", "id": "show_country_flag",  "label": "Country Flag Emoji",   "default": false, "visible_if": { "field": "show_track_label", "value": "true" } }
          ]
        }
      ],
      "pdk": true
    },
    "driver_points": {
      "label": "F1 Driver Points",
      "description": "Show a driver's current championship position and points",
      "disableGallery": true,
      "disableGallary": true,
      "title_readonly": true,
      "default_display": {
        "color": "#1a1a2e",
        "text": "F1"
      },
      "poll": {
        "function": "on_poll",
        "interval_ms": 3600000
      },
      "ui": [
        {
          "type": "api_select",
          "id": "driver_id",
          "label": "Driver",
          "api": "drivers",
          "display": {
            "label": "label",
            "value": "value"
          },
          "default": ""
        },
        {
          "type": "group",
          "id": "driver_display_group",
          "label": "Display",
          "fields": [
            { "type": "checkbox", "id": "show_driver_code",         "label": "Driver Code",        "default": false },
            { "type": "checkbox", "id": "show_driver_position",     "label": "Position",           "default": true  },
            { "type": "checkbox", "id": "show_driver_points",       "label": "Points",             "default": true  },
            { "type": "checkbox", "id": "show_points_from_leader",  "label": "Gap to Leader",      "default": false }
          ]
        }
      ],
      "pdk": true
    },
    "constructor_points": {
      "label": "F1 Constructor Points",
      "description": "Show a constructor's current championship position and points",
      "disableGallery": true,
      "disableGallary": true,
      "title_readonly": true,
      "default_display": {
        "color": "#e10600",
        "text": "F1"
      },
      "poll": {
        "function": "on_poll",
        "interval_ms": 3600000
      },
      "ui": [
        {
          "type": "api_select",
          "id": "constructor_id",
          "label": "Team",
          "api": "constructors",
          "display": {
            "label": "label",
            "value": "value"
          },
          "default": ""
        }
      ],
      "pdk": true
    }
  },
  "pdk": true
}
