<template name="disk_monitor" title="Disk" description="Live disk usage">
  <box class="face">
    <text class="header">Disk</text>
    <text class="{val_class}">{pct}%</text>
    <text class="{sub_class}">{detail}</text>
    <box class="bar-track">
      <progress value="{pct}" track-color="#21262d" fill-color="{bar_color}" height="5" width="100%" />
    </box>
  </box>
</template>
