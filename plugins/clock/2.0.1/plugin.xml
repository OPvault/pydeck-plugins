<template name="clock">
  <box class="face">
    <text class="label">{label}</text>
    <text class="{time_class}">{time}</text>
  </box>
</template>

<template name="clock-date">
  <box class="face">
    <text class="label">{label}</text>
    <text class="{time_class}">{time}</text>
    <box class="divider" />
    <text class="date">{date}</text>
  </box>
</template>
