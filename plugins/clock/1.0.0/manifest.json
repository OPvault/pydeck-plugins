{
  "name": "Clock",
  "version": "1.0.0",
  "description": "Display a live digital clock on a button with Clean or Sketchy style",
  "author": "PyDeck Team",
  "permissions": {
    "datetime": [
      "datetime"
    ],
    "pathlib": [
      "Path"
    ],
    "hashlib": [
      "md5"
    ]
  },
  "functions": {
    "show_clock": {
      "label": "Clock",
      "description": "Live digital clock rendered directly onto the button \u2014 updates every second",
      "title_readonly": true,
      "default_display": {
        "color": "#000000",
        "text": "00:00",
        "text_position": "middle",
        "text_bold": true,
        "text_size": 0,
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_clock",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "select",
          "id": "clock_style",
          "label": "Style",
          "default": "horizontal",
          "options": [
            {
              "label": "Horizontal",
              "value": "horizontal"
            },
            {
              "label": "Vertical",
              "value": "vertical"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_date",
          "label": "Date",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_seconds",
          "label": "Seconds",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hour_12",
          "label": "12 Hour",
          "default": false
        }
      ]
    }
  }
}