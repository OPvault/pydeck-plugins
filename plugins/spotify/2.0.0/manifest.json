{
  "name": "Spotify",
  "version": "2.0.0",
  "description": "Control Spotify playback via the Web API (PDK)",
  "author": "PyDeck Team",
  "min_pydeck_version": "1.1.0",
  "max_pydeck_version": null,
  "oauth": {
    "authorize_url": "https://accounts.spotify.com/authorize",
    "token_url": "https://accounts.spotify.com/api/token",
    "scopes": "user-read-playback-state user-modify-playback-state user-read-currently-playing",
    "auth_method": "basic"
  },
  "credentials": [
    { "id": "client_id",     "label": "Client ID",     "type": "text"     },
    { "id": "client_secret", "label": "Client Secret", "type": "password" }
  ],
  "permissions": {
    "urllib.request": ["urlopen", "Request"],
    "urllib.parse":   ["urlencode"],
    "urllib.error":   ["HTTPError"],
    "base64":         ["b64encode"],
    "json":           ["dumps", "loads"],
    "threading":      ["Lock"],
    "pathlib":        ["Path"]
  },
  "functions": {
    "play_pause": {
      "label": "Play / Pause",
      "description": "Toggle Spotify play/pause with album art display",
      "sidebar_icon": "plugins/plugin/spotify/img/PlayPause.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 1000 },
      "ui": [
        {
          "type": "radio", "id": "display_mode", "label": "Track Label", "default": "song",
          "options": [
            { "value": "none",        "label": "None"          },
            { "value": "song",        "label": "Song"          },
            { "value": "song_artist", "label": "Song - Artist" },
            { "value": "artist",      "label": "Artist"        }
          ]
        },
        { "type": "checkbox", "id": "show_time_left", "label": "Show Time Left", "default": false }
      ],
      "pdk": true
    },
    "next_track": {
      "label": "Next Track",
      "description": "Skip to the next Spotify track",
      "sidebar_icon": "plugins/plugin/spotify/img/Next.png",
      "disableGallery": true,
      "pdk": true
    },
    "prev_track": {
      "label": "Previous Track",
      "description": "Go back to the previous Spotify track",
      "sidebar_icon": "plugins/plugin/spotify/img/Previous.png",
      "disableGallery": true,
      "pdk": true
    },
    "volume_up": {
      "label": "Volume Up",
      "description": "Increase Spotify volume",
      "sidebar_icon": "plugins/plugin/spotify/img/VolumeUp.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 3000 },
      "ui": [
        { "type": "number",   "id": "volume_step",       "label": "Volume Step (%)", "min": 1, "max": 100, "default": 10 },
        { "type": "checkbox", "id": "show_volume_label",  "label": "Show Volume %",  "default": false }
      ],
      "pdk": true
    },
    "volume_down": {
      "label": "Volume Down",
      "description": "Decrease Spotify volume",
      "sidebar_icon": "plugins/plugin/spotify/img/VolumeDown.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 3000 },
      "ui": [
        { "type": "number",   "id": "volume_step",       "label": "Volume Step (%)", "min": 1, "max": 100, "default": 10 },
        { "type": "checkbox", "id": "show_volume_label",  "label": "Show Volume %",  "default": false }
      ],
      "pdk": true
    },
    "set_volume": {
      "label": "Set Volume",
      "description": "Set Spotify playback volume to a specific level (0\u2013100%)",
      "sidebar_icon": "plugins/plugin/spotify/img/Volume.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 3000 },
      "ui": [
        { "type": "number",   "id": "volume_percent",     "label": "Volume (%)",    "min": 0, "max": 100, "default": 50 },
        { "type": "checkbox", "id": "show_volume_label",   "label": "Show Volume %", "default": false }
      ],
      "pdk": true
    },
    "toggle_shuffle": {
      "label": "Shuffle",
      "description": "Toggle Spotify shuffle mode on/off",
      "sidebar_icon": "plugins/plugin/spotify/img/Shuffle.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 5000 },
      "pdk": true
    },
    "cycle_repeat": {
      "label": "Repeat",
      "description": "Cycle repeat mode: off \u2192 context \u2192 track \u2192 off",
      "sidebar_icon": "plugins/plugin/spotify/img/Repeat.png",
      "disableGallery": true,
      "poll": { "function": "on_poll", "interval_ms": 5000 },
      "pdk": true
    }
  },
  "pdk": true
}
