{
  "name": "Spotify",
  "version": "1.0.4",
  "description": "Control Spotify playback via the Web API",
  "author": "PyDeck Team",
  "oauth": {
    "authorize_url": "https://accounts.spotify.com/authorize",
    "token_url": "https://accounts.spotify.com/api/token",
    "scopes": "user-read-playback-state user-modify-playback-state user-read-currently-playing",
    "auth_method": "basic"
  },
  "credentials": [
    {
      "id": "client_id",
      "label": "Client ID",
      "type": "text"
    },
    {
      "id": "client_secret",
      "label": "Client Secret",
      "type": "password"
    }
  ],
  "permissions": {
    "urllib.request": [
      "urlopen",
      "Request"
    ],
    "urllib.parse": [
      "urlencode"
    ],
    "urllib.error": [
      "HTTPError"
    ],
    "base64": [
      "b64encode"
    ],
    "hashlib": [
      "sha256"
    ],
    "json": [
      "dumps",
      "loads"
    ],
    "threading": [
      "Lock"
    ],
    "pathlib": [
      "Path"
    ]
  },
  "functions": {
    "play_pause": {
      "label": "Play / Pause",
      "description": "Toggle Spotify play/pause",
      "sidebar_icon": "plugins/plugin/spotify/img/PlayPause.png",
      "title_readonly": true,
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/storage/spotify/_now_playing.jpg",
        "text_bold": true,
        "text_italic": false,
        "text_underline": false,
        "text_font": "DejaVu Sans"
      },
      "poll": {
        "function": "poll_display",
        "interval_ms": 3000
      },
      "ui": [
        {
          "type": "radio",
          "id": "display_mode",
          "label": "Title",
          "default": "song",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "song",
              "label": "Song"
            },
            {
              "value": "song_artist",
              "label": "Song - Artist"
            },
            {
              "value": "artist",
              "label": "Artist"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_time_left",
          "label": "Show Time Left",
          "default": false
        }
      ]
    },
    "next_track": {
      "label": "Next Track",
      "description": "Skip to the next Spotify track",
      "sidebar_icon": "plugins/plugin/spotify/img/Next.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/Next.png"
      },
      "ui": []
    },
    "prev_track": {
      "label": "Previous Track",
      "description": "Go back to the previous Spotify track",
      "sidebar_icon": "plugins/plugin/spotify/img/Previous.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/Previous.png"
      },
      "ui": []
    },
    "volume_up": {
      "label": "Volume Up",
      "description": "Increase Spotify volume",
      "sidebar_icon": "plugins/plugin/spotify/img/VolumeUp.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/VolumeUp.png"
      },
      "poll": {
        "function": "poll_volume_display",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "number",
          "id": "volume_step",
          "label": "Volume Step (%)",
          "min": 1,
          "max": 100,
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "show_volume_label",
          "label": "Show Volume %",
          "default": false
        }
      ]
    },
    "volume_down": {
      "label": "Volume Down",
      "description": "Decrease Spotify volume",
      "sidebar_icon": "plugins/plugin/spotify/img/VolumeDown.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/VolumeDown.png"
      },
      "poll": {
        "function": "poll_volume_display",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "number",
          "id": "volume_step",
          "label": "Volume Step (%)",
          "min": 1,
          "max": 100,
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "show_volume_label",
          "label": "Show Volume %",
          "default": false
        }
      ]
    },
    "set_volume": {
      "label": "Set Volume",
      "description": "Set Spotify playback volume to a specific level (0\u2013100%)",
      "sidebar_icon": "plugins/plugin/spotify/img/Volume.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/Volume.png"
      },
      "poll": {
        "function": "poll_volume_display",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "number",
          "id": "volume_percent",
          "label": "Volume (%)",
          "min": 0,
          "max": 100,
          "default": 50
        },
        {
          "type": "checkbox",
          "id": "show_volume_label",
          "label": "Show Volume %",
          "default": false
        }
      ]
    },
    "toggle_shuffle": {
      "label": "Shuffle",
      "description": "Toggle Spotify shuffle mode on/off",
      "sidebar_icon": "plugins/plugin/spotify/img/Shuffle.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/Shuffle.png"
      },
      "ui": []
    },
    "cycle_repeat": {
      "label": "Repeat",
      "description": "Cycle repeat mode: off \u2192 context \u2192 track \u2192 off",
      "sidebar_icon": "plugins/plugin/spotify/img/Repeat.png",
      "default_display": {
        "color": "#1ed760",
        "text": "",
        "image": "plugins/plugin/spotify/img/Repeat.png"
      },
      "ui": []
    }
  }
}