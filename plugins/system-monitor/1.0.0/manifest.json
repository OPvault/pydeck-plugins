{
  "name": "System Monitor",
  "version": "1.0.0",
  "description": "Monitor CPU, RAM, GPU, and disk usage via top, sensors, df, and nvidia-smi/rocm-smi — no extra Python packages required",
  "author": "PyDeck Team",
  "permissions": {
    "json": [
      "loads"
    ],
    "os": [
      "statvfs"
    ],
    "pathlib": [
      "Path"
    ],
    "re": [
      "search",
      "IGNORECASE"
    ],
    "shutil": [
      "which"
    ],
    "subprocess": [
      "run"
    ]
  },
  "functions": {
    "cpu_monitor": {
      "label": "CPU",
      "description": "Live CPU usage percentage and optional temperature",
      "title_readonly": true,
      "default_display": {
        "color": "#4f9cf9",
        "text": "CPU\n—",
        "text_size": 18,
        "text_position": "middle",
        "text_bold": true,
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_cpu",
        "interval_ms": 2000
      },
      "ui": [
        {
          "type": "select",
          "id": "cpu_backend",
          "label": "Data Source",
          "default": "auto",
          "options": [
            { "label": "Auto-detect", "value": "auto" },
            { "label": "/proc/stat (kernel, fastest)", "value": "procstat" },
            { "label": "htop (reads /proc/stat)", "value": "htop" },
            { "label": "vmstat", "value": "vmstat" },
            { "label": "mpstat", "value": "mpstat" },
            { "label": "top", "value": "top" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_temp",
          "label": "Show Temperature",
          "default": true
        },
        {
          "type": "select",
          "id": "temp_unit",
          "label": "Temperature Unit",
          "default": "C",
          "options": [
            { "label": "Celsius (°C)", "value": "C" },
            { "label": "Fahrenheit (°F)", "value": "F" }
          ]
        }
      ]
    },
    "ram_monitor": {
      "label": "RAM",
      "description": "Live RAM usage percentage and optional used / total breakdown",
      "title_readonly": true,
      "default_display": {
        "color": "#4f9cf9",
        "text": "RAM\n—",
        "text_size": 13,
        "text_position": "middle",
        "text_bold": true,
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_ram",
        "interval_ms": 2000
      },
      "ui": [
        {
          "type": "select",
          "id": "ram_backend",
          "label": "Data Source",
          "default": "auto",
          "options": [
            { "label": "Auto-detect", "value": "auto" },
            { "label": "/proc/meminfo (kernel, fastest)", "value": "procmeminfo" },
            { "label": "htop (reads /proc/meminfo)", "value": "htop" },
            { "label": "free", "value": "free" },
            { "label": "top", "value": "top" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_used",
          "label": "Show Used / Total",
          "default": true
        }
      ]
    },
    "gpu_monitor": {
      "label": "GPU",
      "description": "Live GPU temperature and utilisation — nvidia-smi (NVIDIA proprietary), rocm-smi (AMD), or /sys/class/drm sysfs (NVIDIA nouveau, AMD, Intel — the same interface nvtop uses)",
      "title_readonly": true,
      "default_display": {
        "color": "#0f172a",
        "text": "GPU\nN/A",
        "text_size": 18,
        "text_position": "middle",
        "text_bold": true,
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_gpu",
        "interval_ms": 3000
      },
      "ui": [
        {
          "type": "select",
          "id": "gpu_backend",
          "label": "Backend",
          "default": "auto",
          "options": [
            { "label": "Auto-detect", "value": "auto" },
            { "label": "NVIDIA (nvidia-smi)", "value": "nvidia" },
            { "label": "AMD (rocm-smi)", "value": "amd" },
            { "label": "nvtop / NVIDIA / AMD / Intel (sysfs)", "value": "nvtop" }
          ]
        },
        {
          "type": "checkbox",
          "id": "show_usage",
          "label": "Show Usage %",
          "default": true
        },
        {
          "type": "select",
          "id": "temp_unit",
          "label": "Temperature Unit",
          "default": "C",
          "options": [
            { "label": "Celsius (°C)", "value": "C" },
            { "label": "Fahrenheit (°F)", "value": "F" }
          ]
        }
      ]
    },
    "disk_monitor": {
      "label": "Disk",
      "description": "Live disk usage for a chosen mount point",
      "title_readonly": true,
      "default_display": {
        "color": "#4f9cf9",
        "text": "Disk\n—",
        "text_size": 12,
        "text_position": "middle",
        "text_bold": true,
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_disk",
        "interval_ms": 10000
      },
      "ui": [
        {
          "type": "select",
          "id": "disk_backend",
          "label": "Data Source",
          "default": "auto",
          "options": [
            { "label": "Auto-detect", "value": "auto" },
            { "label": "os.statvfs (kernel syscall, fastest)", "value": "statvfs" },
            { "label": "df", "value": "df" }
          ]
        },
        {
          "type": "input",
          "id": "path",
          "label": "Mount Point",
          "default": "/"
        }
      ]
    }
  }
}
