{
  "name": "MET",
  "version": "1.0.0",
  "description": "Show current weather from met.no for a chosen location",
  "author": "PyDeck Team",
  "permissions": {
    "json": ["loads"],
    "urllib.request": ["Request", "urlopen"],
    "urllib.parse": ["urlencode"],
    "urllib.error": ["HTTPError", "URLError"],
    "pathlib": ["Path"],
    "re": ["match"]
  },
  "functions": {
    "show_weather": {
      "label": "MET",
      "description": "Display current temperature and/or weather condition",
      "title_readonly": true,
      "default_display": {
        "color": "#3a6ea5",
        "text": "Weather",
        "text_position": "bottom",
        "scroll_enabled": false
      },
      "poll": {
        "function": "poll_weather",
        "interval_ms": 1000
      },
      "ui": [
        {
          "type": "input",
          "id": "location",
          "label": "Location (city or lat,lon)",
          "placeholder": "Oslo or 59.91,10.75",
          "default": "Oslo",
          "autosave": "off",
          "help_text": "Find a location on MET and copy city name or coordinates:",
          "help_label": "Open MET Location Forecast",
          "help_url": "https://www.yr.no/en"
        },
        {
          "type": "checkbox",
          "id": "show_temperature",
          "label": "Show Current Temperature",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_condition",
          "label": "Show Weather Condition (sunny, rainy, etc.)",
          "default": false
        },
        {
          "type": "select",
          "id": "temperature_unit",
          "label": "Temperature Unit",
          "default": "C",
          "options": [
            {
              "label": "Celsius (C)",
              "value": "C"
            },
            {
              "label": "Fahrenheit (F)",
              "value": "F"
            }
          ]
        }
      ]
    }
  }
}
